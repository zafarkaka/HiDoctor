# =================================
# HiDoctor Backend — Production Env
# =================================
# Copy this to .env and fill in your values

# ==========================================
# HiDoctor Backend - Environment Variables
# ==========================================

# Database - Use MongoDB Atlas for Production
MONGO_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/hidoctor?retryWrites=true&w=majority
DB_NAME=hidoctor

# Authentication
JWT_SECRET=generate-a-long-random-string-here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# URLs
BACKEND_URL=https://hidoctor-api.fly.dev
FRONTEND_URL=https://hidoctor.vercel.app

# Optional: Port (default is 8001 in Docker)
PORT=8001

# Stripe (optional — for payment processing)
STRIPE_API_KEY=sk_test_your_stripe_key_here

# Razorpay (optional — for Indian payments)
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# OpenRouter (optional — for AI doctor recommendations)
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here
